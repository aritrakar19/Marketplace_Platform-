# Google OAuth (YouTube) + session — merge into backend/.env

# CORS: Vite dev server (comma-separated for multiple origins in production)
# FRONTEND_ORIGIN=http://localhost:5173

# SESSION_SECRET=long-random-string
# MONGO_URI=mongodb://...  (strongly recommended so OAuth state survives restarts / multiple Node processes)

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# e.g. http://localhost:5001/auth/youtube/callback
GOOGLE_REDIRECT_URI=
