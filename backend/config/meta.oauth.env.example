# Meta (Facebook Login + Instagram Graph API) — copy values into your root `.env`
# App: https://developers.facebook.com/apps/

META_APP_ID=
META_APP_SECRET=

# Must match exactly the “Valid OAuth Redirect URIs” in the Meta app settings.
# Example: http://localhost:5000/auth/meta/callback
META_REDIRECT_URI=

# Optional (default v18.0)
# META_GRAPH_VERSION=v18.0
